# Rust
/target
**/*.rs.bk
Cargo.lock.orig

# macOS
.DS_Store

# Large baked assets (regenerable via data-pipeline / batch)
/crates/app-interactive/assets/processed/

# Raw data snapshots are large and regenerable (fetched via the documented
# curl/DuckDB/Overpass steps); never commit them.
/data/snapshots/

# Python virtualenv for the OSMnx export step
/.venv
__pycache__/

# Web build output
#   web/dist/ IS committed: GitHub Pages deploys the prebuilt bundle as-is
#   (the WASM build + the gitignored baked assets can't be reproduced in CI).
#   Rebuild with ./web/build.sh and commit before pushing — see
#   .github/workflows/deploy.yml.
/web/node_modules

# Agent/editor tooling — installed skills + local Claude Code config, not
# part of the our·space project source.
/.agents
/.claude
/skills-lock.json
